# Copy to `.env` and fill in. `.env` is gitignored and never committed.
# In the Fly.io cloud deployment these are set with `fly secrets set` instead
# (see README → Deployment); they are read from the environment either way.

# --- Turso (hosted libSQL) database ---
# From `turso db show job-search-agent --url` and `turso db tokens create job-search-agent`.
# For local dev you may instead point at a throwaway local file, e.g.
#   TURSO_DATABASE_URL=file:dev.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Anthropic (A-day: Claude Deep Research) ---
ANTHROPIC_API_KEY=

# --- Perplexity (B-day: Pro Search) ---
PERPLEXITY_API_KEY=
